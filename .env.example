# Copy to `.env`, fill in, never commit.
# run_brief.sh sources this before invoking Python.

# Companies House (already provided)
COMPANIES_HOUSE_KEY=<your-companies-house-api-key>

# Bright Data free tier — 5k requests/month for licensed logged-off LinkedIn surface
BRIGHT_DATA_KEY=<your-bright-data-api-token>
# Name of the Web Unlocker zone provisioned on your Bright Data account.
# Must be a Web Unlocker zone (not Datacenter/Residential). REQUIRED alongside
# the key — without it BRIGHT_DATA_KEY alone logs bright_data=OFF and the
# Google/LinkedIn sources stay disabled.
BRIGHT_DATA_ZONE=<your-web-unlocker-zone-name>

# --- Email delivery (pick Resend OR Gmail) ---

# Option A: Resend (free tier: 100/day). Sign up at resend.com.
# IMPORTANT: with onboarding@resend.dev as RESEND_FROM, you can only send to the
# email address you registered your Resend account with. To send to arbitrary
# addresses (like amirt12@hotmail.com or stehrani@vmagroup.com) you must verify
# a domain on resend.com first.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# Option B: Gmail SMTP (works to any inbox, no domain setup needed).
# Steps:
#   1. myaccount.google.com/security → enable 2-Step Verification
#   2. myaccount.google.com/apppasswords → generate one for "Mail"
#   3. Paste the 16-char app password below (spaces stripped are fine)
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=Sara's Morning Brief

# --- SEND OUTREACH (the button on Live Jobs) ---
# Hunter.io email find + verify (free tier: ~25 searches / 50 verifies
# per month). hunter.io -> API -> copy key. Without it the engine uses
# FREE sources only (the job ad itself, RNS enquiries blocks, model web
# research) and pattern guesses are never one-click sendable either way.
HUNTER_API_KEY=
# Persistent monthly spend caps (state/hunter_ledger.json enforces them
# across runs). Defaults sit BELOW the free tier so the account owner's
# own manual hunter.io searches aren't starved. Raise after upgrading.
HUNTER_MONTHLY_SEARCH_BUDGET=20
HUNTER_MONTHLY_VERIFY_BUDGET=40
# Per-job contact research (model + live web search) passes per brief
# run. 25 covers every newly-appearing job within a day at the 7-day
# re-research TTL.
OUTREACH_RESEARCH_MAX_JOBS=25
# Test-first send switch. While unset/1/true, every send reroutes to the
# profile's test inbox (amirt12@hotmail.com for comms) with the would-be
# recipient stamped on it. Set to 0 to send live. Misspellings fail SAFE
# (test mode).
OUTREACH_TEST_MODE=1
# Display name outreach is sent under (default: the desk's AD).
OUTREACH_FROM_NAME=

# Adzuna UK (optional, free, adds Indeed + 10+ boards coverage)
# Register at developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Charity Commission for England & Wales register API (optional, FREE).
# Register for a subscription key at https://api.charitycommission.gov.uk/
# Enables the charity trustee-board-change BD signal. Without it the charity
# register lane is a clean no-op (charity vacancies still flow via the
# CharityJob / CharityComms / NHS Jobs feeds, which need no key).
# Crunchbase Basic API (optional, free tier: 200 req/min).
# Register at https://www.crunchbase.com/account/integrations
# Proactively detects UK funding rounds (Series A-E, £20m+) before
# they hit the news graph — complements the GDELT/RSS news detector.
CRUNCHBASE_API_KEY=

CHARITY_COMMISSION_KEY=

# Companies House Streaming API (optional). Set to 1 ONLY in an always-on
# worker — the daily cron can't hold a long-lived socket, so it stays off by
# default and the same data is polled via the REST charges/PSC/filing-history
# lanes. Uses the same COMPANIES_HOUSE_KEY above.
CH_STREAM_ENABLED=

# --- Local dashboard only (start_dashboard.command) ---
# GitHub Personal Access Token so the dashboard can dispatch workflows
# and download brief artifacts. Generate at:
#   https://github.com/settings/personal-access-tokens/new
# Permissions: Actions (read+write), Contents (read), repo: atst2026/VMA
GITHUB_TOKEN=
GITHUB_OWNER=atst2026
GITHUB_REPO=VMA
